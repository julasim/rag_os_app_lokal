# ==============================================================================
# SIMA RAG-System — Umgebungsvariablen
#
# Kopiere diese Datei nach .env und trage echte Werte ein.
# Die .env wird NIE eingecheckt (siehe .gitignore).
# ==============================================================================

# ------------------------------------------------------------------------------
# Deine Domain (für Caddy / HTTPS)
# ------------------------------------------------------------------------------
# Beispiel: rag.sima.or.at
# Caddy holt automatisch ein Let's-Encrypt-Zertifikat, wenn die Domain auf
# diesen VPS zeigt.
#
# WICHTIG: exakt die Domain eintragen, die (a) einen DNS-A-Record auf diesen VPS
# hat UND (b) einen Caddy-Block im Edge-Proxy (/opt/Proxy) besitzt. Kein Tippfehler
# / falsche TLD — sonst schlägt `make health` fehl (Could not resolve host) und
# CORS erlaubt die falsche Origin. Prod-Wert dieses Deployments: rag-os.sima.business
RAG_DOMAIN=rag.deinedomain.at

# ------------------------------------------------------------------------------
# Admin-UI — der erste User wird beim ersten Start automatisch angelegt
# ------------------------------------------------------------------------------
ADMIN_EMAIL=julius@sima.or.at
ADMIN_PASSWORD=bitte-aendern-mindestens-16-zeichen

# Wird für Session-Cookies und Token-Signatur verwendet.
# Generiere mit: python -c "import secrets; print(secrets.token_urlsafe(48))"
APP_SECRET_KEY=bitte-durch-eigenen-zufallswert-ersetzen

# ------------------------------------------------------------------------------
# Postgres
# ------------------------------------------------------------------------------
POSTGRES_DB=rag
POSTGRES_USER=rag
POSTGRES_PASSWORD=bitte-aendern

# ------------------------------------------------------------------------------
# Qdrant
# ------------------------------------------------------------------------------
# API-Key schützt Qdrant auch im internen Netz (defense in depth).
# Generiere mit: python -c "import secrets; print(secrets.token_urlsafe(32))"
QDRANT_API_KEY=bitte-durch-eigenen-zufallswert-ersetzen

# ------------------------------------------------------------------------------
# MCP-Server — OAuth 2.1 für Claude.ai (standardmäßig AN)
#
# OAuth ist per Default aktiv — KEINE Konfiguration nötig. Login läuft gegen die
# echten Admin-UI-Accounts (ADMIN_EMAIL/ADMIN_PASSWORD bzw. weitere ui_users),
# Clients + Refresh-Tokens liegen in Postgres. Claude.ai erkennt den Server über
# die .well-known-Endpunkte und öffnet den Browser zur Anmeldung.
#
# Es gibt KEINE separaten OAuth-Credentials mehr (OAUTH_USER_EMAIL/
# OAUTH_PASSWORD_HASH sind entfallen). Das JWT-Secret fällt auf APP_SECRET_KEY
# zurück, wenn OAUTH_JWT_SECRET leer ist.
# ------------------------------------------------------------------------------

# OAuth komplett abschalten (dann nur statische Bearer-API-Keys): OAUTH_ENABLED=false
# OAUTH_ENABLED=true

# Optionales dediziertes JWT-Secret (sonst = APP_SECRET_KEY). Generiere mit:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
# OAUTH_JWT_SECRET=

# Token-Lebensdauern in Sekunden (Defaults: Access 900 = 15 min, Refresh 259200 = 3 Tage)
# OAUTH_ACCESS_TTL=900
# OAUTH_REFRESH_TTL=259200

# ------------------------------------------------------------------------------
# MCP-Server — Rate-Limiting (OPTIONAL)
# Maximale Anfragen pro Minute und Client-IP. 0 = deaktiviert.
# ------------------------------------------------------------------------------
MCP_RATE_LIMIT_PER_MIN=60

# ------------------------------------------------------------------------------
# MCP-Server — Audit-Log (OPTIONAL)
# Pfad zur JSONL-Datei. Leer lassen = deaktiviert.
# ------------------------------------------------------------------------------
MCP_AUDIT_LOG=/data/mcp-audit.log
